<Window x:Class="Hiemdall_bridge.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Login"
        Height="460"
        Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <!--Background="#F4F6FB">-->
    <Window.Resources>
        <!-- Ensure the raised button style preserves a white Foreground -->
        <Style x:Key="RaisedWhiteForegroundButton" TargetType="Button"
       BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Storyboard x:Key="EyeToggleAnimation">
            <!-- Rotate -->
            <DoubleAnimation Storyboard.TargetName="EyeRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0"
                             To="180"
                             Duration="0:0:0.25"
                             AutoReverse="True"/>

            <!-- Fade -->
            <DoubleAnimation Storyboard.TargetName="EyeIcon"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0.3"
                             Duration="0:0:0.12"
                             AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- Card -->
        <Border Width="340"
                CornerRadius="18"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.25"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="#3F51B5"
                        CornerRadius="18,18,0,0">
                    <Grid>
                        <TextBlock Text=" Bridge"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Form -->
                <StackPanel Grid.Row="1" Margin="26">

                    <!-- Username -->
                    <Grid Margin="0,24,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Kind="Account"
                                                 VerticalAlignment="Center"
                                                 Foreground="#3F51B5"/>

                        <TextBox x:Name="txtname" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Column="1"
                                 FontSize="15"
                                 materialDesign:HintAssist.Hint="Username"
                                 materialDesign:TextFieldAssist.UnderlineBrush="#3F51B5"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    </Grid>

                    <!-- Password -->
                    <Grid Margin="0,10,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Kind="Lock"
                                                 VerticalAlignment="Center"
                                                 Foreground="#3F51B5"/>

                        <PasswordBox x:Name="PasswordHidden"
                                     Grid.Column="1" 
                                     FontSize="15" 
                                     materialDesign:HintAssist.Hint="Password"
                                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>

                        <TextBox x:Name="PasswordVisible"
                                 Grid.Column="1"
                                 FontSize="15"  
                                 Visibility="Collapsed"
                                 materialDesign:HintAssist.Hint="Password"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                        <!-- Eye Button: Centered Icon -->
                        <Button Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="TogglePasswordVisibility_Click"
                                Width="32"
                                Height="32"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="0">
                            <!-- Horizontal and Vertical Center content -->
                            <materialDesign:PackIcon x:Name="EyeIcon"
                                                     Kind="Eye"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="#3F51B5"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                <materialDesign:PackIcon.RenderTransform>
                                    <RotateTransform x:Name="EyeRotate"
                                                     Angle="0"
                                                     CenterX="10"
                                                     CenterY="10"/>
                                </materialDesign:PackIcon.RenderTransform>
                            </materialDesign:PackIcon>
                        </Button>
                    </Grid>

                    <!-- Login Button -->
                    <Button Content="LOGIN"
                            Margin="0,10,0,10"
                            Height="44"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="#3F51B5"                           
                            Style="{StaticResource RaisedWhiteForegroundButton}"
                            Foreground="White"
                          
                   Click="LoginButton_Click"/>

                    <!-- Close Button -->
                    <Button Content="CLOSE"
                            Height="44"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="#FFEA4220"
                            Foreground="White"                           
                            Style="{StaticResource RaisedWhiteForegroundButton}"
                            
                          Command="{Binding CloseCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>