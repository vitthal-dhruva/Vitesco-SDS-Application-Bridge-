<Window x:Class="Hiemdall_bridge.Form2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"        
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"                
        Title="Bridge" MinHeight="750" MinWidth="1150"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanMinimize" x:Name="Form1">
    <Window.Resources>
        <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignTabItem}">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="white"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="16,8"/>

            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#00796B"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>


    </Window.Resources>

    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24*"/>
            <ColumnDefinition Width="551*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="10"  BorderBrush="#DADADA" BorderThickness="0,0,0,1" Grid.ColumnSpan="2" Margin="0,0,0,0" >
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Company Name -->
                <TextBlock Grid.Column="0" Text="Schaeffler Special Machinary" FontSize="18"  FontWeight="Bold"  Foreground="#00796B"
                   HorizontalAlignment="Left"  Margin="10,0,0,0" VerticalAlignment="Center"/>

                <!-- Application Title -->
                <TextBlock Grid.Column="1" Text="Bridge" FontSize="30"  FontWeight="Bold" Foreground="#00796B"  HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

                <!-- Station Info -->
                <!--<TextBlock Grid.Column="2"  Text="M4C Assembly Station" FontSize="16" HorizontalAlignment="Right" Margin="0,0,10,0"  VerticalAlignment="Center"/>-->
                <Grid Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
             Text="M4C Assembly Station"
             FontSize="16"
             VerticalAlignment="Center"
             Margin="0,0,10,0"/>

                    <TextBlock Grid.Column="1" Text="{Binding CurUser}"  FontSize="16" VerticalAlignment="Center" Margin="20,0,10,0"
                       HorizontalAlignment="Right"    Foreground="#00796B"    />
                    <Border Grid.Column="2"
        Background="Transparent"
        VerticalAlignment="Center"
        Margin="0,0,10,0"
        Cursor="Hand"
        ToolTipService.ShowDuration="2000"
        MouseLeftButtonDown="Logout_Click">
                        <Border.ToolTip>
                            <ToolTip Background="White" BorderBrush="#DADADA" BorderThickness="1" Padding="5">
                                <TextBlock Text="LogOut" Foreground="Black" />
                            </ToolTip>
                        </Border.ToolTip>

                        <materialDesign:PackIcon Kind="Logout"
                             Width="22"
                             Height="22"
                             Foreground="#E53935"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             IsHitTestVisible="False" />
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Margin="2,2,2,2" Grid.ColumnSpan="2">

            <TabItem Header="MES General Settings">

                <Grid Margin="0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TOP SECTION -->
                    <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- General Settings -->
                            <GroupBox Header="General Settings" Background="#FFFFFAFA"  Padding="5" Grid.Column="0">
                                <Grid>
                                    <!-- Two columns: Label | Input -->
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- One row per field -->
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Equipment ID -->
                                    <TextBlock Text="Equipment ID" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,5,0,5" materialDesign:HintAssist.Hint="HTS_PCBPRESS"    x:Name="txtEquipmentId"
                                     materialDesign:TextFieldAssist.UnderlineBrush="#c2254d" Text="{Binding Config.StationName, Mode=TwoWay}" 
                                     materialDesign:TextFieldAssist.TextFieldCornerRadius="5" Grid.ColumnSpan="2"/>

                                    <!-- IP Address -->
                                    <TextBlock Text="IP Address" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,5,0,5" x:Name="IPAddress" Text="{Binding Config.IPAddress, Mode=TwoWay}"
                                     materialDesign:TextFieldAssist.UnderlineBrush="#c2254d" materialDesign:HintAssist.Hint="127.0.0.1"
                                     materialDesign:TextFieldAssist.TextFieldCornerRadius="5" Grid.ColumnSpan="2"/>

                                    <!-- Port No -->
                                    <TextBlock Text="Port No" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2"  Grid.Column="1"  Margin="0,5,0,5" InputScope="Number"  x:Name="Port" Text="{Binding Config.Port, Mode=TwoWay}"
                                    materialDesign:TextFieldAssist.UnderlineBrush="#c2254d" 
                   PreviewTextInput="Integer_PreviewTextInput"
  PreviewKeyDown="Integer_PreviewKeyDown"
  DataObject.Pasting="Integer_Pasting"
  LostFocus="Integer_LostFocus" materialDesign:HintAssist.Hint="8085"
                                    materialDesign:TextFieldAssist.TextFieldCornerRadius="5" Grid.ColumnSpan="2"/>

                                    <!-- Records to Display -->
                                    <TextBlock Text="Records to Display" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3"  Grid.Column="1"   Margin="0,5,0,5" x:Name="Records_Display" Text="{Binding Config.MaxRows, Mode=TwoWay}"
                                    materialDesign:TextFieldAssist.UnderlineBrush="#c2254d" InputScope="Number"   PreviewTextInput="Integer_PreviewTextInput"
  PreviewKeyDown="Integer_PreviewKeyDown"
  DataObject.Pasting="Integer_Pasting" materialDesign:HintAssist.Hint="100"
  LostFocus="Integer_LostFocus"
                                    materialDesign:TextFieldAssist.TextFieldCornerRadius="5" Grid.ColumnSpan="2"/>

                                    <!-- MES Timer Row with 3 columns -->
                                    <TextBlock Grid.Row="4" Grid.Column="0"   Text="MES Timer (Sec)" VerticalAlignment="Center"/>

                                    <Grid Grid.Row="4" Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- MES Timer TextBox -->
                                        <TextBox Grid.Column="0" InputScope="Number"  x:Name="Mes_Timer"   HorizontalAlignment="Stretch"  Margin="0,5,10,5"                                         
                                        materialDesign:TextFieldAssist.UnderlineBrush="#c2254d"   PreviewTextInput="Integer_PreviewTextInput"
  PreviewKeyDown="Integer_PreviewKeyDown"  Text="{Binding Config.Timer, Mode=TwoWay}"
  DataObject.Pasting="Integer_Pasting" materialDesign:HintAssist.Hint="5"
  LostFocus="Integer_LostFocus"
                                         materialDesign:TextFieldAssist.TextFieldCornerRadius="5"/>

                                        <!-- Save Button -->

                                        <Button Content="Save" Grid.Column="1" Command="{Binding SaveConfigCommand}"  Width="200"  Height="40"   x:Name="Tab1_Save"
                                               HorizontalAlignment="Left" IsEnabled="{Binding IsAdmin}"  VerticalAlignment="Center"
                                                Style="{StaticResource GreenButton}">

                                        </Button>
                                    </Grid>
                                </Grid>
                            </GroupBox>


                            <!-- MES Information -->
                            <GroupBox Header="MES Information" Grid.Column="1" Padding="5" Margin="5,5,5,10"  Background="#FFFFFAFA" >
                                <Grid  Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Two columns: Label | Input -->
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- One row per field -->
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock  Text="MES Connection" Margin="10" Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" />
                                    <Ellipse x:Name="MESLed" Width="25" Height="25" Fill="{Binding MesLedBrush}" Stroke="Black" StrokeThickness="2"  Grid.Column="1" Grid.Row="0"/>
                                    <TextBlock Text="PLC Connection" Margin="10"  Grid.Column="0" Grid.Row="2" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="PLCLed" Width="25" Height="25" Fill="{Binding PLCLedBrush}" Stroke="Black" StrokeThickness="2"   Grid.Column="1" Grid.Row="2"/>

                                </Grid>
                            </GroupBox>
                        </Grid>
                    </ScrollViewer>

                    <!-- Log Grid -->

                    <Grid Grid.Row="1" Margin="10,0,10,0" Grid.ColumnSpan="2">
                        <Border Margin="0" >
                            <DataGrid IsReadOnly="True" 
          x:Name="dgLogs" 
          ItemsSource="{Binding LogVM.LogItems}"  
          RowBackground="#F7F9FC"
          AlternatingRowBackground="#E3F2FD" 
          HorizontalScrollBarVisibility="Disabled">

                                <DataGrid.Columns>
                                    <!-- Sr No Column -->
                                    <DataGridTextColumn Header="Sr No" 
                            Binding="{Binding SrNo}" 
                            Width="auto">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="LightGray"/>
                                                <Setter Property="Padding" Value="20,0,0,0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="20,0,0,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Date Time Column -->
                                    <DataGridTextColumn Header="Date Time" 
                            Binding="{Binding DateTime}" 
                            Width="auto">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="LightGray"/>
                                                <Setter Property="Padding" Value="20,0,0,0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="20,0,0,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- State Column -->
                                    <DataGridTextColumn Header="State" 
                            Binding="{Binding State}" 
                            Width="auto">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="LightGray"/>
                                                <Setter Property="Padding" Value="20,0,0,0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="20,0,0,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Message Column -->
                                    <DataGridTextColumn Header="Message" 
                            Binding="{Binding Message}" 
                            Width="*">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="LightGray"/>
                                                <Setter Property="Padding" Value="20,0,0,0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Left"/>
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding Message}"/>
                                                <Setter Property="Padding" Value="20,0,0,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Tag Configuration" x:Name="TabTagConfig">
                <Grid  DataContext="{Binding TagConfigVM}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="1" Padding="5,5,5,5">
                        <Grid Height="220">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions >
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Command Type"  HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1"  ItemsSource="{Binding CommandTypes}"
                          SelectedItem="{Binding SelectedCommandType}"
                             Grid.ColumnSpan="2"  Margin="10,0,20,0" x:Name="cbCommandType"  materialDesign:HintAssist.Hint="Request"
                             materialDesign:TextFieldAssist.UnderlineBrush="#c2254d" materialDesign:TextFieldAssist.TextFieldCornerRadius="5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Command Name"   HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="1" Grid.Column="1"   Grid.ColumnSpan="2"  Margin="10,0,20,0" x:Name="cbCommandNames"
                            materialDesign:HintAssist.Hint="Ping" ItemsSource="{Binding Commands}"
                          SelectedItem="{Binding SelectedCommand}" DisplayMemberPath="CommandName" 
                            SelectedValuePath="Id" materialDesign:TextFieldAssist.UnderlineBrush="#c2254d"
                            materialDesign:TextFieldAssist.TextFieldCornerRadius="5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Parameter Name"   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1"  materialDesign:HintAssist.Hint="Tokens" x:Name="txtParameterName"
                             materialDesign:TextFieldAssist.UnderlineBrush="#c2254d" Grid.ColumnSpan="2"  Margin="10,0,20,5" Text="{Binding ParameterName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:TextFieldAssist.TextFieldCornerRadius="5" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Node Address"   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1"  materialDesign:HintAssist.Hint="ns=2,i=1033" x:Name="txtNodeID"
                             materialDesign:TextFieldAssist.UnderlineBrush="#c2254d" Grid.ColumnSpan="2"  Margin="10,0,20,5" Text="{Binding NodeID, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:TextFieldAssist.TextFieldCornerRadius="5" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Data Type"  VerticalAlignment="Center"/>

                            <Grid Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- DataType ComboBox -->
                                <ComboBox x:Name="cbDatatypes"  Grid.Column="0" ItemsSource="{Binding PlcDataTypes}"
                              SelectedItem="{Binding SelectedPlcDataType}" Margin="10,0,10,5"
                                 materialDesign:HintAssist.Hint="Int" materialDesign:TextFieldAssist.UnderlineBrush="#c2254d"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="5"/>

                                <!-- IsActive Checkbox -->
                                <CheckBox x:Name="chkIsActive"  Grid.Column="1" IsChecked="{Binding IsActive ,FallbackValue=True}" Content="Is Active"  VerticalAlignment="Center" Margin="70,0,20,0" Foreground="Black">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Foreground" Value="Gray"/>
                                            <Style.Triggers>
                                                <!-- When checked -->
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Background" Value="#1976D2"/>
                                                </Trigger>
                                                <!-- When unchecked -->
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter Property="Foreground" Value="Black"/>
                                                    <Setter Property="Background" Value="#E0E0E0"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                            </Grid>
                            <Grid Grid.Row="5" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button  Grid.Column="0"  Margin="10,0,20,0" Width="200" Height="40"  x:Name="savebutton"
                                   Command="{Binding SaveCommand}" IsEnabled="{Binding IsAdmin}" Content="{Binding SaveButtonText}" HorizontalAlignment="Left" VerticalAlignment="Center"
                                         Style="{StaticResource GreenButton}">

                                </Button>
                                <Button  Margin="20,0,0,0"
        Grid.Column="1"
        Grid.Row="5"
        Width="200"
        Height="40"
        Content="Clear"
        Command="{Binding ResetCommand}"
        HorizontalAlignment="left" Style="{StaticResource GrayButton}"
        VerticalAlignment="Center">
                                </Button>
                            </Grid>

                        </Grid>
                    </GroupBox>
                    <Border Margin="5" Grid.Row="2" BorderBrush="#DADADA" BorderThickness="1" Background="White">

                        <DataGrid x:Name="TagConfigs" 
          HorizontalScrollBarVisibility="Disabled"  
          HorizontalAlignment="Center" 
          ItemsSource="{Binding TagConfigs}" 
          AutoGenerateColumns="False" 
          RowBackground="AliceBlue" 
          AlternatingRowBackground="Transparent" 
          IsReadOnly="True">

                            <DataGrid.Columns>
                                <!-- SR NO -->
                                <DataGridTextColumn Header="Sr No"  
                            Width="Auto" 
                            Binding="{Binding SrNo}">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Command Type -->
                                <DataGridTextColumn Header="Type" 
                            Width="100" 
                            Binding="{Binding CommandType}">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- COMMAND NAME -->
                                <DataGridTextColumn Header="Command Name" 
                            Width="*" 
                            Binding="{Binding CommandName}">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="ToolTip" Value="{Binding CommandName}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- PARAMETER -->
                                <DataGridTextColumn Header="Parameter" 
                            Width="*" 
                            Binding="{Binding ParameterName}">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="ToolTip" Value="{Binding ParameterName}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- NodeID -->
                                <DataGridTextColumn Header="NodeId" 
                            Width="*" 
                            Binding="{Binding NodeID}">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="ToolTip" Value="{Binding NodeID}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Datatype NAME -->
                                <DataGridTextColumn Header="Data Type" 
                            Width="*" 
                            Binding="{Binding DataType}">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- IsActive -->
                                <DataGridTextColumn Header="IsActive" 
                            Width="*" 
                            Binding="{Binding IsActive}">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- ACTION - Edit Button -->
                                <DataGridTemplateColumn Header="Edit" 
                                Width="100">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Edit" 
                            IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                            Style="{StaticResource DataGridEditButtonStyle}"  
                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                            CommandParameter="{Binding}" 
                            Tag="{Binding}"
                            HorizontalAlignment="Left"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- ACTION - Delete Button -->
                                <DataGridTemplateColumn Header="Delete" 
                                Width="100">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightGray"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5,1,1"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Delete" 
                            IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=DataGrid}}"  
                            Style="{StaticResource DataGridDeleteButtonStyle}" 
                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                            CommandParameter="{Binding}"  
                            Tag="{Binding}"
                            HorizontalAlignment="Left"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

            </TabItem>
            <TabItem Header="Sequence Log Messages" x:Name="information">
                <Grid Margin="0" DataContext="{Binding SequenceLogVM}" >
                    <Grid.RowDefinitions>
                        <!--Auto height for the filter bar, Star height for the grid-->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 1. FILTER BAR (StackPanel) -->
                    <Border Grid.Row="0" 
            Background="#FFFFFF" 
            BorderBrush="#E2E8F0" 
            BorderThickness="1" 
            CornerRadius="8" 
                            Height="50"
            Padding="5" 
            Margin="5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                        </Border.Effect>
                        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- From label -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- From picker -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- spacer -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- To label -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- To picker -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- spacer -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Search -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Reset -->
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- From Date -->
                                <!-- From label and picker (same row) -->
                                <TextBlock Grid.Column="0"
             Text="From"
             FontSize="15"
             FontWeight="SemiBold"
             Foreground="#475569"
             VerticalAlignment="Center"
             Margin="0,0,8,0"/>
                                <xctk:DateTimePicker Grid.Column="1"
                       x:Name="dpFromDate"
                       Width="200"
                       Height="34" Value="{Binding FromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Format="Custom"
                       FormatString="yyyy-MM-dd HH:mm:ss"
                       TimeFormat="Custom"
                       TimeFormatString="HH:mm:ss"
                       Background="White"
                       Foreground="Black"
                       VerticalAlignment="Center"/>

                                <!-- To label and picker (same row) -->
                                <TextBlock Grid.Column="3" Text="To" FontSize="15" FontWeight="SemiBold" Foreground="#475569"  VerticalAlignment="Center" Margin="30,0,8,0"/>
                                <xctk:DateTimePicker Grid.Column="4" Value="{Binding ToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" x:Name="ToDatePicker" Width="200" Height="34" Format="Custom" FormatString="yyyy-MM-dd HH:mm:ss"
                                  TimeFormat="Custom" TimeFormatString="HH:mm:ss" Background="White" Foreground="Black" VerticalAlignment="Center"/>
                                <!-- Search Button -->
                                <Button x:Name="BtnSearch" Style="{StaticResource GreenButton}" Content="Search"  Grid.Column="4" Width="100"  Height="32" Margin="30,0,0,0" Cursor="Hand"   Foreground="White" Command="{Binding SearchCommand}" FontWeight="Bold">

                                </Button>
                                <!-- Optional Clear Button -->
                                <Button x:Name="BtnClear" Style="{StaticResource GrayButton}" Content="Reset" Grid.Column="5"  Width="100"  Height="32"  Margin="30,0,0,0" Command="{Binding ResetCommand}"  Foreground="#64748B">

                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Margin="5" Grid.Row="1"  BorderBrush="#DADADA" BorderThickness="1" Background="White">
                        <DataGrid AutoGenerateColumns="False" 
          IsReadOnly="True" 
          x:Name="dgLogss"  
          HorizontalContentAlignment="Stretch" 
          VerticalContentAlignment="Stretch" 
          ItemsSource="{Binding MesLogs}"  
          RowBackground="LightCyan" 
          AlternatingRowBackground="Transparent"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          ScrollViewer.CanContentScroll="True"
          Margin="0,0,0,1"
          EnableRowVirtualization="True"
          EnableColumnVirtualization="True"
          VirtualizingPanel.IsVirtualizing="True"
          VirtualizingPanel.VirtualizationMode="Recycling"
          VerticalAlignment="Stretch"
          HorizontalAlignment="Stretch">

                            <DataGrid.Columns>
                                <!-- Sr No Column -->
                                <DataGridTextColumn Header="Sr No" 
                            Binding="{Binding SrNo}" 
                            Width="Auto" 
                            MinWidth="50">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightBlue"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="TextAlignment" Value="Left"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Time Column -->
                                <DataGridTextColumn Header="Time" 
                            Binding="{Binding DateTime}" 
                            Width="Auto" 
                            MinWidth="150">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightBlue"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="TextAlignment" Value="Left"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- State Column -->
                                <DataGridTextColumn Header="State" 
                            Binding="{Binding State}" 
                            Width="Auto" 
                            MinWidth="130">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightBlue"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="TextAlignment" Value="Left"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Message Column -->
                                <DataGridTextColumn Header="Message" 
                            Binding="{Binding Message}" 
                            Width="*" 
                            MinWidth="300">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="LightBlue"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>

                                            <Setter Property="ToolTip">
                                                <Setter.Value>
                                                    <ToolTip Placement="Mouse"
                         MaxWidth="800"
                         Background="LightYellow"
                         BorderBrush="LightBlue"
                         BorderThickness="1">

                                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  MaxHeight="500">

                                                            <TextBlock Text="{Binding Message}"
                                   TextWrapping="Wrap"
                                   Foreground="Black"
                                   FontSize="14"
                                   Padding="10"/>
                                                        </ScrollViewer>

                                                    </ToolTip>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

            </TabItem>
            <TabItem Header="User Authentication" x:Name="TabUser" MouseEnter="TabUser_Selected" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <GroupBox Header="User Configuration" FontFamily="Calibri" FontSize="14" Margin="5">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>

                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Role Type -->
                            <TextBlock Text="Role Type" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" SelectedIndex="0" x:Name="cbRoleTypeTab4"  Margin="10,5">
                                <ComboBoxItem Content="----Select----"/>
                                <ComboBoxItem Content="Admin"/>
                                <ComboBoxItem Content="User"/>
                            </ComboBox>

                            <!-- Username -->
                            <TextBlock Text="Username" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtUsernameTab4" Text="" Margin="10,5"/>

                            <!-- Password -->
                            <TextBlock Text="Password"     Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtPasswordTab4"  Margin="10,5"/>



                            <!-- Buttons -->
                            <Grid Grid.Row="5" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button  Grid.Column="0"  IsEnabled="{Binding IsAdmin}"  Margin="10,0,20,0" Width="200" Height="40"  x:Name="saveUserbutton"
                                   Click="Save_Button_TAB4" Content="{Binding UserAuthVM.SaveButtonContent}" 
                        HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource GreenButton}">
                                </Button>
                                <Button Content="Reset" Margin="20,0,0,0"
        Grid.Column="1"
        Grid.Row="5"
        Width="200"
        Height="40"
        Click="Reset_Button_Tab4"
        HorizontalAlignment="left" Style="{StaticResource GrayButton}"
        VerticalAlignment="Center">

                                </Button>
                            </Grid>

                        </Grid>
                    </GroupBox>
                    <DataGrid Grid.Row="1" HorizontalAlignment="Center" x:Name="dgUsers" ItemsSource="{Binding UserAuthVM.Users}" IsReadOnly="True"
          Margin="10" HorizontalScrollBarVisibility="Disabled" RowBackground="LightBlue" AlternatingRowBackground="LightGray"
          
          AutoGenerateColumns="False"
          CanUserAddRows="False">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" ElementStyle="{StaticResource CenterAlignedCell}" Width="Auto"/>
                            <DataGridTextColumn Header="Role Type" Binding="{Binding RoleType}" ElementStyle="{StaticResource CenterAlignedCell}" Width="*"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" ElementStyle="{StaticResource CenterAlignedCell}" Width="*"/>

                            <DataGridTemplateColumn Header="Edit" Width="*" CellStyle="{StaticResource CenterButtonCell}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Edit" IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Click="EditUser_Click" Style="{StaticResource DataGridEditButtonStyle}" Tag="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Delete" Width="*" CellStyle="{StaticResource CenterButtonCell}" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Delete"  IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                              Style="{StaticResource DataGridDeleteButtonStyle}" Command="{Binding DataContext.UserAuthVM.DeleteUserCommand, 
                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                    CommandParameter="{Binding}"  Tag="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
        <!-- Footer -->
        <Border Grid.Row="2"
 Background="White"
 Padding="10,10,10,20"
 BorderBrush="#DADADA"
 BorderThickness="0,1,0,0" Grid.ColumnSpan="2" Margin="0,0,0,0" Grid.RowSpan="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

                    <!-- Company Name -->
                    <TextBlock Text="Schaeffler"
                FontSize="18"
                FontWeight="Bold"
                Foreground="#00796B"
                Margin="0,0,10,0"
                VerticalAlignment="Center"/>

                    <!-- Developer Info -->
                    <TextBlock Text="| Developed by SDS Team 2026"
                FontSize="14"
                Foreground="Black"
                VerticalAlignment="Center"/>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
